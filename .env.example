# ── LLM Providers ─────────────────────────────────
OLLAMA_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Broker API ────────────────────────────────────
DENOCLAW_API_TOKEN=

# ── Deno Deploy ───────────────────────────────────
DENO_DEPLOY_ORG_TOKEN=
DENO_DEPLOY_PAT=

# ── Dashboard Auth (GitHub OAuth, optional) ───────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Postgres Analytics (optional — KV used if absent)
# DATABASE_URL=postgresql://denoclaw:denoclaw@localhost:5432/denoclaw

# ── Embeddings (optional — for Mastra vector search)
# Uses the same Ollama Cloud instance and API key as LLM providers.
# EMBEDDER_PROVIDER=ollama              # "ollama" (cloud) or "fastembed" (local FFI)
# OLLAMA_EMBED_MODEL=nomic-embed-text   # embedding model on your Ollama instance
