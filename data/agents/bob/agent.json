{
  "description": "Execution agent",
  "sandbox": {
    "allowedPermissions": [
      "read",
      "write",
      "run",
      "net"
    ],
    "execPolicy": {
      "security": "allowlist",
      "allowedCommands": [
        "echo",
        "ls",
        "cat",
        "date",
        "deno",
        "node",
        "python3"
      ]
    }
  },
  "peers": [
    "alice"
  ],
  "acceptFrom": [
    "alice"
  ]
}
