{
  "name": "@denoclaw/denoclaw",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "tasks": {
    "dev": "deno run --watch --unstable-kv --unstable-cron --allow-all --env main.ts",
    "start": "deno run --unstable-kv --unstable-cron --allow-all --env main.ts",
    "gateway": "deno run --unstable-kv --unstable-cron --allow-all --env main.ts gateway",
    "test": "deno test --unstable-kv --allow-all",
    "check": "deno check main.ts mod.ts",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/fmt": "jsr:@std/fmt@^1",
    "@std/async": "jsr:@std/async@^1",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true
  }
}
