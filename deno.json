{
  "name": "@denoclaw/denoclaw",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --watch --unstable-kv --unstable-cron --allow-all --env main.ts dev",
    "start": "deno run --unstable-kv --unstable-cron --allow-all --env main.ts dev",
    "deploy": "deno run --unstable-kv --unstable-cron --allow-all --env main.ts deploy",
    "publish": "deno run --unstable-kv --unstable-cron --allow-all --env main.ts publish",
    "dashboard:dev": "DENOCLAW_DASHBOARD_AUTH_MODE=token deno run -A npm:vite --config vite.config.ts",
    "dashboard:build": "deno run -A npm:vite build --config vite.config.ts",
    "dashboard:preview": "DENOCLAW_DASHBOARD_AUTH_MODE=token deno run -A npm:vite preview --config vite.config.ts",
    "db:generate": "deno run -A npm:prisma generate",
    "db:push": "deno run -A npm:prisma db push",
    "db:migrate": "deno run -A npm:prisma migrate dev",
    "db:studio": "deno run -A npm:prisma studio",
    "test": "deno test --unstable-kv --unstable-cron --allow-all --env src/",
    "test:all": "deno test --unstable-kv --unstable-cron --allow-all --env src/ tests/",
    "test:unit": "deno test --unstable-kv --allow-all src/",
    "test:boundaries": "deno test --allow-read src/shared/import_boundaries_test.ts",
    "test:e2e": "deno test --unstable-kv --unstable-cron --allow-all --env tests/",
    "check": "deno check main.ts mod.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "sync-agents": "deno run --allow-all --env scripts/sync_agents.ts"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@^1",
    "@std/log": "jsr:@std/log@^0.224",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "@std/path": "jsr:@std/path@^1",
    "@std/fmt": "jsr:@std/fmt@^1",
    "@std/async": "jsr:@std/async@^1",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@discordeno/bot": "npm:@discordeno/bot@^21",
    "grammy": "npm:grammy@^1",
    "@deno/oidc": "jsr:@deno/oidc@^0",
    "@deno/sandbox": "jsr:@deno/sandbox@^0",
    "jose": "jsr:@panva/jose@^6",
    "@olli/kvdex": "jsr:@olli/kvdex@^3",
    "fresh": "jsr:@fresh/core@^2",
    "@fresh/core": "jsr:@fresh/core@^2",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1",
    "preact": "npm:preact@^10",
    "preact/jsx-runtime": "npm:preact@^10/jsx-runtime",
    "preact/jsx-dev-runtime": "npm:preact@^10/jsx-dev-runtime",
    "@preact/signals": "npm:@preact/signals@^2",
    "vite": "npm:vite@^7",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4",
    "tailwindcss": "npm:tailwindcss@^4",
    "daisyui": "npm:daisyui@^5.5.19",
    "@prisma/client": "npm:@prisma/client@^7",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7",
    "@mastra/memory": "npm:@mastra/memory@^0.15",
    "@mastra/pg": "npm:@mastra/pg@^0.17",
    "@mastra/fastembed": "npm:@mastra/fastembed@^0.10"
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "lint": {
    "exclude": ["src/db/generated/"]
  },
  "unstable": [
    "kv",
    "cron"
  ],
  "deploy": {
    "org": "casys",
    "app": "denoclaw-broker"
  }
}
